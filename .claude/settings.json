{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-prereqs.sh",
            "shell": "bash",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/notify-done.ps1",
            "shell": "bash",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-sensitive.sh",
            "shell": "bash",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-edit-write.sh",
            "shell": "bash"
          },
          {
            "type": "command",
            "command": "bash scripts/validate-rule.sh",
            "shell": "bash",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
